    create or replace table `data-platform-455517`.`substack`.`int__substack_subscriber_daily`
      
    
    

    
    OPTIONS(
      description=""""""
    )
    as (
      

with subscribers as (
    select *
    from `data-platform-455517`.`substack`.`stg__substack_subscribers`
),

stripe_subs as (
    select
        s.subscription_id as stripe_subscription_id,
        c.email,
        case when date_diff(
                date(s.current_period_end),
                date(s.current_period_start),
                day
                ) > 300 then 'annual'
                else 'monthly'
            end as stripe_billing_interval,
        s.status as stripe_status,
        s.current_period_start,
        s.current_period_end,
        s.cancel_at_period_end,
        s.canceled_at
    from `data-platform-455517`.`stripe`.`stg__stripe_subscriptions` s
    left join `data-platform-455517`.`stripe`.`stg__stripe_customers` c
        on s.customer_id = c.customer_id
    qualify row_number() over (
        partition by lower(trim(c.email))
        order by s._fivetran_start desc
    ) = 1
)
    select
    --substack spine
    ss.snapshot_date,
    ss.publication,
    ss.subscription_id,
    ss.user_id,
    ss.email,
    ss.subscription_interval,
    ss.stripe_plan_name,
    ss.paid_attribution,
    ss.is_subscribed,
    ss.is_comp,
    ss.is_gift,
    ss.is_free_trial,
    ss.activity_rating,
    ss.subscription_created_at,
    ss.first_payment_at,
    ss.subscription_expires_at,
    ss_unsubscribed_at
    --stripe enrichment
    str.stripe_subscription_id,
    str.stripe_status,
    str.current_period_start,
    str.current_period_end,
    str.cancel_at_period_end,
    str.canceled_at,
    --derived fields
    coalesce(
        str.stripe_billing_interval,
        case
            when lower(ss.stripe_plan_name) like '%year%'  then 'annual'
            when lower(ss.stripe_plan_name) like '%month%' then 'monthly'
        end
    )                                   as billing_interval,

    safe_cast(
        regexp_extract(ss.stripe_plan_name, r'\$(\d+(?:\.\d+)?)')
        as float64
    )                                   as imputed_price_usd,

    (
        ss.first_payment_at is not null
        and str.stripe_subscription_id is null
    )                                   as is_non_stripe_paid

    from subscribers ss
    left join stripe_subs str
        on lower(trim(ss.email)) = lower(trim(str.email))
    );
  
