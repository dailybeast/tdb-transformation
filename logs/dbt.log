                    then (d1+d2+d3+d4+d5) - greatest(d1,d2,d3,d4,d5) - least(d1,d2,d3,d4,d5) / 2
                    else d5           
            ) / 31.0,        
            2) as projected_revenue
), live_starts as (
    
    select
        billing_interval,
        count(distinct subscription_id) as starts_to_date
    from `data-platform-455517.stripe.int__stripe_substack_subscriptions`
    cross join reporting_window rw 
    where date(subscription_created_at)
        between rw.period_start and current_date()
    group by 1

), live_churn as (

    select 
        billing_interval,
        count(distinct subscription_id) as churn_to_date
    from `data-platform-455517.stripe.int__stripe_substack_subscriptions`
    cross join reporting_window rw  
