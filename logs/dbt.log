with reporting_window as (
    select 
        case
            when extract(day from current_date()) >= 16
                then date_add(date_trunc(current_date(), month), interval 1 month)
            else date_trunc(current_date(), month)
            end as finance_month_date
),

next_month as (

    select 
        finance_month_date,
        format_date('%B %Y', finance_month_date) as projected_reporting_month,
        date_add(
            date_sub(finance_month_date, interval 1 month),
            interval 15 day
        ) as reporting_month_start,
        date_add(finance_month_date, interval 14 day) as reporting_month_end
    from reporting_window
    ),

completed_months as (

    select
        distinct reporting_month
    from `data-platform-455517`.`stripe`.`fct__stripe_substack_month_accrual`
    where reporting_month_end < current_date()
    qualify row_number() over (order by reporting_month_end desc) <= 3
),

historical_churn as (
    
    select
        billing_interval,
        format_date('%B %Y',
            case when extract(day from date(canceled_at)) >= 16
                then date_trunc(date_add(date(canceled_at), interval 1 month), month)
            else date_trunc(date(canceled_at), month)
            end) as reporting_month,
        count(distinct subscription_id) as churn_count
    from `data-platform-455517`.`stripe`.`int__stripe_substack_subscriptions`
),

median_churn as (
    select
        billing_interval,
        percentile_cont(churn_count, 0.5) over (
            partition by billing_interval
        ) as median_churn_count
    from historical_churn
    qualify row_number() over (
        partition by billing_interval
        order by churn_count
    ) = 1
),

historical_starts as (
    select
        billing_interval,
        format_date('%B %Y',
            case when extract(day from date(canceled_at)) >= 16
                then date_trunc(date_add(date(canceled_at), interval 1 month), month)
            else date_trunc(date(canceled_at), month)
            end) as reporting_month,
        count(distinct subscription_id)
    from `data-platform-455517`.`stripe`.`int__stripe_substack_subscriptions`
    where subscription_created_at is not null
    group by 1, 2
),

median_starts as (
    select
        billing_interval,
        percentile_cont(start_count, 0.5) over (
            partition by billing_interval
        )                                                       as median_start_count
    from historical_starts
    where reporting_month in (select reporting_month from completed_months)
    qualify row_number() over (
        partition by billing_interval order by start_count
    ) = 1
),

avg_revenue as (
    select
        billing_interval,
        avg(
            safe_divide(recognized_revenue_usd, subscriber_count)
        )                                                       as avg_revenue_per_sub
    from `data-platform-455517`.`stripe`.`fct__stripe_substack_month_accrual`
    where revenue_type = 'subscriber'
        and reporting_month in (select reporting_month from completed_months)
    group by 1
),
--only subs with renewals falling in the projected window
monthly_base as (

    select 
        sum(last_invoice_usd) as scheduled_revenue,
        count(distinct subscription_id) as renewal_count,
    from `data-platform-455517`.`stripe`.`int__stripe_substack_subscriptions`
    cross join next_month nm
    where status = 'active'
        and billing_interval = 'monthly'
        and not coalesce(cancel_at_period_end, false)
        and date(current_period_end)
            between nm.reporting_month_start and nm.reporting_month_end
), 

-- annual: all active annual subs, ongoing 1/12 recognition
annual_base as (
    select
        sum(last_invoice_amount_usd) / 12.0                    as scheduled_revenue,
        count(*)                                                as active_count
    from `data-platform-455517`.`stripe`.`int__stripe_substack_subscriptions`
    where status = 'active'
        and billing_interval = 'annual'
        and not coalesce(cancel_at_period_end, false)
),

appstore_estimate as (
    select net_amount_usd  as projected_revenue
    from `data-platform-455517`.`stripe`.`int__stripe_appstore_payouts`
    order by charged_at desc
    limit 1
)

select
    nm.projected_reporting_month,
    nm.reporting_month_start,
    nm.reporting_month_end,
    'subscriber' as revenue_type,
    'monthly' as billing_interval,
    mb.scheduled_revenue,
    coalesce(mc.median_churn_count, 0)
        * coalesce(ar.avg_revenue_per_sub, 0) as expected_churn_revenue,
    coalesce(ms.median_start_count, 0)
        * coalesce(ar.avg_revenue_per_sub, 0) as expected_new_start_revenue,
    mb.scheduled_revenue
        - (coalesce(mc.median_churn_count, 0) * coalesce(ar.avg_revenue_per_sub, 0))
        + (coalesce(ms.median_start_count, 0) * coalesce(ar.avg_revenue_per_sub, 0)) as projected_recognized_revenue,
    'projected' as projection_type
from monthly_base mb
cross join next_month nm
left join median_churn mc   on mc.billing_interval = 'monthly'
left join median_starts ms  on ms.billing_interval = 'monthly'
left join avg_revenue ar    on ar.billing_interval = 'monthly'

union all

select
    nm.projected_reporting_month,
    nm.reporting_month_start,
    nm.reporting_month_end,
    'subscriber' as revenue_type,
    'annual' as billing_interval,
    ab.scheduled_revenue,
    coalesce(mc.median_churn_count, 0)
        * coalesce(ar.avg_revenue_per_sub, 0)                  as expected_churn_revenue,
    coalesce(ms.median_start_count, 0)
        * coalesce(ar.avg_revenue_per_sub, 0)                  as expected_new_start_revenue,
    ab.scheduled_revenue
        - (coalesce(mc.median_churn_count, 0) * coalesce(ar.avg_revenue_per_sub, 0))
        + (coalesce(ms.median_start_count, 0) * coalesce(ar.avg_revenue_per_sub, 0))
                                                                as projected_recognized_revenue,
    'projected'                                                 as projection_type
from annual_base ab
cross join next_month nm
left join median_churn mc   on mc.billing_interval = 'annual'
left join median_starts ms  on ms.billing_interval = 'annual'
left join avg_revenue ar    on ar.billing_interval = 'annual'

union all

select
    nm.projected_reporting_month,
    nm.reporting_month_start,
    nm.reporting_month_end,
    'app_store'                                                 as revenue_type,
    null                                                        as billing_interval,
    ae.projected_revenue                                        as scheduled_revenue,
    null                                                        as expected_churn_revenue,
    null                                                        as expected_new_start_revenue,
    ae.projected_revenue                                        as projected_recognized_revenue,
    'projected'                                                 as projection_type
from appstore_estimate ae
cross join next_month nm
